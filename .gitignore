# === Python ===
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
.ruff_cache/

# === Obsidian (local UI only; not part of three-zone layout) ===
.trash/
.obsidian/

# === Runtime dirs inside the vault (gitignored, regenerated on demand) ===
# Three-zone layout: code + knowledge are tracked; runtime churn is local.
# cache/    — search / QMD / vector indexes
# logs/     — lint reports, compile logs, SessionStart debug dumps
# run/      — state.json, compile.pid, queue/, locks
# Override root via LLM_WIKI_STATE_ROOT (tests use a temp dir).
cache/
logs/
run/
state/
.ci-lint-state/

# === Personal session data (private, NOT in git) ===
knowledge/daily/*.md
# Public Evidence fixtures (synthetic; no personal content)
!knowledge/daily/2026-04-13.md
!knowledge/daily/2026-04-19.md
!knowledge/daily/README.md
# Empty local scratch dailies stay ignored (no un-ignore for 2026-07-*)

# === Knowledge allowlist ===
# Personal/user notes are blocked; public system-self-knowledge samples are un-ignored.
knowledge/notes/*
!knowledge/notes/README.md
!knowledge/notes/*.md
# Nested personal categories stay ignored unless explicitly published:
knowledge/notes/*/**

# === Per-project state ===
knowledge/projects/*
!knowledge/projects/_template/
!knowledge/projects/README.md

# === Personal feedback / staging ===
knowledge/feedback/
knowledge/inbox/**
!knowledge/inbox/README.md
knowledge/raw/**
!knowledge/raw/README.md

# === Skills allowlist ===
# Only the 9 public memory-system skills ship in this repo.
skills/*
!skills/bridge-promote-insight/
!skills/contradict-check/
!skills/crystallize-playbook/
!skills/knowledge-compile/
!skills/knowledge-lookup/
!skills/knowledge-qa-file-back/
!skills/knowledge-review/
!skills/session-memory-compile/
!skills/session-memory-review/

# === Gitleaks / audit artifacts ===
gitleaks-report.json
gitleaks-report.sarif

# === Secrets ===
*.env
*.env.local
secrets/

# === OS / IDE junk ===
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.swp
*.swo

# === Runtime lock files ===
*.pid
state.json.lock

# === Backups ===
*.bak-*