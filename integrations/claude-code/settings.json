{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./private/**)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(uv run python scripts/search_memory.py *)",
      "Bash(uv run python scripts/lookup_mode.py *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(sed *)",
      "Bash(head *)",
      "Bash(basename *)",
      "Bash(xargs *)",
      "Bash(echo *)",
      "Bash(python scripts/search_memory.py *)",
      "Bash(python scripts/lookup_mode.py *)",
      "Bash(uv run python scripts/search_memory.py *)",
      "Bash(uv run python scripts/lookup_mode.py *)",
      "Bash(uv run --directory *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/session_start_context.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/session_start_project_state.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/precompact_capture.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/session_end_capture.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/session_end_project_tag.py",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/user_prompt_capture.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory \"$LLM_WIKI_ROOT\" python scripts/post_tool_capture.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
