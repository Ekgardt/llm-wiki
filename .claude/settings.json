{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",
      "Read(./private/**)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(qmd *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(sed *)",
      "Bash(head *)",
      "Bash(basename *)",
      "Bash(xargs *)",
      "Bash(echo *)",
      "Bash(python scripts/*.py)",
      "Bash(uv run python scripts/*.py)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python scripts/session_start_context.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python scripts/precompact_capture.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python scripts/session_end_capture.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}